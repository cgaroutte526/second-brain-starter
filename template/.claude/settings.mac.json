{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/load-context.sh\"",
            "timeout": 10,
            "statusMessage": "Loading vault context..."
          }
        ]
      }
    ]
  }
}
